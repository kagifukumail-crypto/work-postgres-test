# Copy this file to ".env" in this folder for local emulator / development.
# NEVER commit ".env" (it is gitignored).

PGHOST=192.168.1.15
PGPORT=5432
PGDATABASE=towaDB
PGUSER=your_db_user
PGPASSWORD=your_secret_password

# --- Production (Google Cloud) ---
# Set the same variable names in Cloud Functions runtime:
#   Firebase Console -> Functions -> getData -> Configuration -> Environment variables
# Or: gcloud functions deploy ... --set-env-vars PGHOST=...,PGPASSWORD=...
#
# IMPORTANT: Cloud Functions cannot reach a LAN-only PostgreSQL (192.168.x) unless you use
# Serverless VPC Access + VPC connector + VPN / Cloud VPN / hybrid connectivity.
# Options: migrate DB to Cloud SQL with authorized networks, or expose via secure tunnel.
